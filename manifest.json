{
  "manifest_version": 3,
  "name": "ConsentSync – Control Your Data",
  "version": "0.6.1",
  "description": "Real-time privacy dashboard with AI policy analysis, risk score, and automation. Control your data with confidence.",
  "action": {
    "default_popup": "popup.html"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "unsafe_blocklist.json"
      ],
      "matches": ["<all_urls>"]
    }
  ],
  "permissions": [
    "alarms",
    "cookies",
    "storage",
    "tabs",
    "scripting",
    "contentSettings",
    "notifications",
    "webNavigation",
    "downloads"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "service_worker.js"
  },
  "icons": {
    "128": "icons/icon.svg"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle",
      "all_frames": true
    }
  ],
  "options_ui": {
    "page": "dashboard.html",
    "open_in_tab": true
  }
}